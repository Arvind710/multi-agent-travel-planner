# ── Local dev defaults (docker-compose.dev.yml) ────────────────────────────
DATABASE_URL=postgres://raah:raah@localhost:5432/raah
REDIS_URL=redis://localhost:6379

# Object storage (MinIO locally; Cloudflare R2 in prod)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=raah
S3_SECRET_ACCESS_KEY=raah-dev-secret
S3_BUCKET=raah-dev

# ── Apps ────────────────────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
PROVIDER_MOCKS_URL=http://localhost:4010

# ── Auth (P0.9) ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=dev-secret-change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Resend (email magic links) — free tier key from resend.com
AUTH_RESEND_KEY=
EMAIL_FROM=Raah <onboarding@resend.dev>

# ── Workers ─────────────────────────────────────────────────────────────────
PLAN_GENERATE_CONCURRENCY=1
PLAN_REVISE_CONCURRENCY=2
PLAN_EXPORT_CONCURRENCY=1
WATCH_PRICE_CONCURRENCY=1
KB_INGEST_CONCURRENCY=1
NOTIFY_CONCURRENCY=2
PLAN_TOKEN_BUDGET=250000

# ── LLM providers (free-tier-first, ARCH §7.6 / ADR-013) ───────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
# OpenAI: Critic only, $5 hard cap set in dashboard (ADR-014)
OPENAI_API_KEY=

# ── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
OTEL_ENABLED=false
LOG_LEVEL=info
